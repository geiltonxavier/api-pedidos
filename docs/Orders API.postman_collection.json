{
  "info": {
    "name": "Orders API",
    "description": "API para gerenciamento de pedidos de loja online",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5024"
    },
    {
      "key": "orderId",
      "value": ""
    },
    {
      "key": "itemId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Criar Pedido",
      "item": [
        {
          "name": "POST - Pedido Standard (sem desconto)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Retorna orderId', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.orderId).to.be.a('string');",
                  "    pm.collectionVariables.set('orderId', json.orderId);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": 0,\n  \"items\": [\n    {\n      \"description\": \"Camiseta\",\n      \"quantity\": 2,\n      \"unitPrice\": 49.90\n    },\n    {\n      \"description\": \"Boné\",\n      \"quantity\": 1,\n      \"unitPrice\": 29.90\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/orders",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "orders"]
            }
          }
        },
        {
          "name": "POST - Pedido Express (acréscimo 15%)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Retorna orderId', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.orderId).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": 1,\n  \"items\": [\n    {\n      \"description\": \"Tênis\",\n      \"quantity\": 1,\n      \"unitPrice\": 199.90\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/orders",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "orders"]
            }
          }
        },
        {
          "name": "POST - Pedido Subscription (desconto 10%)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Retorna orderId', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.orderId).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": 2,\n  \"items\": [\n    {\n      \"description\": \"Mochila\",\n      \"quantity\": 1,\n      \"unitPrice\": 150.00\n    },\n    {\n      \"description\": \"Garrafa Térmica\",\n      \"quantity\": 2,\n      \"unitPrice\": 45.00\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/orders",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "orders"]
            }
          }
        },
        {
          "name": "POST - Idempotência (mesma key = mesma resposta)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Replayed header presente', () => {",
                  "    // Na segunda execução com mesma key, esse header aparece",
                  "    // pm.expect(pm.response.headers.get('X-Idempotency-Replayed')).to.eql('true');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "chave-fixa-para-teste-idempotencia" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": 0,\n  \"items\": [\n    {\n      \"description\": \"Produto Teste\",\n      \"quantity\": 1,\n      \"unitPrice\": 10.00\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/orders",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "orders"]
            }
          }
        }
      ]
    },
    {
      "name": "Consultar Pedido",
      "item": [
        {
          "name": "GET - Resumo do pedido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Contém campos esperados', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.expect(json).to.have.property('type');",
                  "    pm.expect(json).to.have.property('subTotal');",
                  "    pm.expect(json).to.have.property('total');",
                  "    pm.expect(json).to.have.property('discountValue');",
                  "    pm.expect(json).to.have.property('items');",
                  "    pm.expect(json.items).to.be.an('array');",
                  "});",
                  "pm.test('Salva itemId do primeiro item', () => {",
                  "    const json = pm.response.json();",
                  "    if (json.items && json.items.length > 0) {",
                  "        // Nota: o itemId não é retornado no DTO atual",
                  "        // Se for adicionado, descomente a linha abaixo",
                  "        // pm.collectionVariables.set('itemId', json.items[0].id);",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "orders", "{{orderId}}"]
            }
          }
        },
        {
          "name": "GET - Pedido inexistente (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/orders/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "orders", "00000000-0000-0000-0000-000000000000"]
            }
          }
        }
      ]
    },
    {
      "name": "Atualizar Item",
      "item": [
        {
          "name": "PUT - Atualizar item do pedido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Total recalculado', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('total');",
                  "    pm.expect(json).to.have.property('subTotal');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Camiseta G (atualizada)\",\n  \"quantity\": 3,\n  \"unitPrice\": 54.90\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/orders/{{orderId}}/items/{{itemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "orders", "{{orderId}}", "items", "{{itemId}}"]
            }
          }
        },
        {
          "name": "PUT - Item inexistente (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Produto fantasma\",\n  \"quantity\": 1,\n  \"unitPrice\": 10.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/orders/{{orderId}}/items/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "orders", "{{orderId}}", "items", "00000000-0000-0000-0000-000000000000"]
            }
          }
        }
      ]
    },
    {
      "name": "Remover Item",
      "item": [
        {
          "name": "DELETE - Remover item do pedido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/orders/{{orderId}}/items/{{itemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "orders", "{{orderId}}", "items", "{{itemId}}"]
            }
          }
        },
        {
          "name": "DELETE - Item inexistente (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/orders/{{orderId}}/items/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "orders", "{{orderId}}", "items", "00000000-0000-0000-0000-000000000000"]
            }
          }
        }
      ]
    }
  ]
}
